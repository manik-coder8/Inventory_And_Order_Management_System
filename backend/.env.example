# Copy this file to .env and fill in real values. Never commit the real .env file.

# PostgreSQL connection string used by the backend
DATABASE_URL=postgresql://posXXXX

# Comma-separated list of origins allowed to call this API
CORS_ORIGINS=http://localhost:XXXX,http://localhost:XXXX

# Quantity at or below which a product is flagged as "low stock"
LOW_STOCK_THRESHOLD=XXXX
