# Copy this file to .env in the project root before running `docker compose up`.
# Never commit the real .env file.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=XXXX
POSTGRES_DB=XXXX

CORS_ORIGINS=http://localhost:XXXX,http://localhost:5173,http://localhost:XXXX

LOW_STOCK_THRESHOLD=10

# Used at frontend build time so the React app knows where the API lives.
VITE_API_URL=http://localhost:XXXX
